{
  "name": "prole-coder-vscode",
  "displayName": "ProleCoder",
  "description": "VS Code extension for ProleCoder.",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "publisher": "prole-coder",
  "type": "commonjs",
  "engines": {
    "node": ">=24.0.0",
    "vscode": "^1.100.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:prole-coder.openChat",
    "onCommand:prole-coder.openSettings",
    "onView:prole-coder.chat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prole-coder.openChat",
        "title": "ProleCoder: Open Chat"
      },
      {
        "command": "prole-coder.openSettings",
        "title": "ProleCoder: Open Settings"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prole-coder",
          "title": "ProleCoder",
          "icon": "media/prole-coder-view.svg"
        }
      ]
    },
    "views": {
      "prole-coder": [
        {
          "type": "webview",
          "id": "prole-coder.chat",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "ProleCoder",
      "properties": {
        "prole-coder.rpc.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start the Rust Agent RPC server when the extension activates in a trusted workspace."
        },
        "prole-coder.rpc.command": {
          "type": "string",
          "default": "prole",
          "description": "Command used to launch the Rust Agent RPC server."
        },
        "prole-coder.rpc.args": {
          "type": "array",
          "default": ["rpc"],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the Rust Agent RPC server command."
        },
        "prole-coder.fim.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable ProleCoder inline FIM completion previews when the connected RPC server reports FIM-capable provider data."
        },
        "prole-coder.fim.model": {
          "type": "string",
          "default": "",
          "description": "Optional model id for FIM previews. Leave empty to use the RPC server default model from provider capabilities."
        },
        "prole-coder.fim.maxTokens": {
          "type": "integer",
          "default": 128,
          "minimum": 1,
          "maximum": 4096,
          "description": "Maximum completion tokens requested for FIM previews."
        },
        "prole-coder.fim.maxContextChars": {
          "type": "integer",
          "default": 12000,
          "minimum": 1000,
          "maximum": 100000,
          "description": "Maximum prefix and suffix characters sent to the RPC server for a FIM preview."
        }
      }
    }
  },
  "scripts": {
    "build": "pnpm --filter @prole-coder/protocol build && tsc -p tsconfig.json",
    "lint": "pnpm --filter @prole-coder/protocol build && tsc -p tsconfig.test.json --noEmit",
    "package": "vsce package",
    "test:electron": "pnpm run build && tsc -p tsconfig.test.json && node scripts/runVscodeIntegrationTests.mjs",
    "vsix:alpha": "pnpm run build && node scripts/packageAlphaVsix.mjs",
    "vsix:smoke": "pnpm run build && node scripts/vsixDryRunSmoke.mjs",
    "test": "pnpm --filter @prole-coder/protocol build && tsc -p tsconfig.test.json && node --test \"out-test/**/*.test.js\"",
    "typecheck": "pnpm --filter @prole-coder/protocol build && tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@prole-coder/protocol": "workspace:*",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.100.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.8.0"
  }
}
