{
  "name": "deepseek-coder-vscode",
  "displayName": "deepseek-coder",
  "description": "VS Code extension for deepseek-coder.",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "publisher": "deepseek-coder",
  "type": "commonjs",
  "engines": {
    "node": ">=24.0.0",
    "vscode": "^1.100.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished", "onCommand:deepseek-coder.openChat"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deepseek-coder.openChat",
        "title": "deepseek-coder: Open Chat"
      }
    ],
    "configuration": {
      "title": "deepseek-coder",
      "properties": {
        "deepseek-coder.rpc.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start the Rust Agent RPC server when the extension activates in a trusted workspace."
        },
        "deepseek-coder.rpc.command": {
          "type": "string",
          "default": "deepseek-coder",
          "description": "Command used to launch the Rust Agent RPC server."
        },
        "deepseek-coder.rpc.args": {
          "type": "array",
          "default": ["rpc"],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the Rust Agent RPC server command."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "package": "vsce package",
    "test": "tsc -p tsconfig.test.json && node --test \"out-test/**/*.test.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.100.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.8.0"
  }
}
